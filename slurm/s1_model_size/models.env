#!/bin/bash
# Central configuration for the S1 model-size DenseLinear ablation.
# Sourced by every stage script and by the launchers. All values are
# overridable from the environment (export VAR=... before launching).

# ---- Sweep order (sequential across model sizes) --------------------------
# 0.5B is an optional small anchor; not in the default sweep order.
S1MS_TAGS=(qwen2_5_1_5b qwen2_5_3b qwen2_5_7b qwen2_5_14b qwen2_5_32b)

# ---- tag -> HuggingFace model id ------------------------------------------
declare -A S1MS_MODEL_ID=(
  [qwen2_5_0_5b]=Qwen/Qwen2.5-0.5B
  [qwen2_5_1_5b]=Qwen/Qwen2.5-1.5B
  [qwen2_5_3b]=Qwen/Qwen2.5-3B
  [qwen2_5_7b]=Qwen/Qwen2.5-7B
  [qwen2_5_14b]=Qwen/Qwen2.5-14B
  [qwen2_5_32b]=Qwen/Qwen2.5-32B
)

# ---- tag -> human params label --------------------------------------------
declare -A S1MS_PARAMS_LABEL=(
  [qwen2_5_0_5b]=0.5B
  [qwen2_5_1_5b]=1.5B
  [qwen2_5_3b]=3B
  [qwen2_5_7b]=7B
  [qwen2_5_14b]=14B
  [qwen2_5_32b]=32B
)

# ---- tag -> starting encode batch size (auto-halves on OOM) ---------------
declare -A S1MS_BATCH=(
  [qwen2_5_0_5b]=32
  [qwen2_5_1_5b]=32
  [qwen2_5_3b]=32
  [qwen2_5_7b]=16
  [qwen2_5_14b]=4
  [qwen2_5_32b]=1
)

# ---- ProcessBench subsets (Stage C array index -> subset) -----------------
S1MS_SUBSETS=(gsm8k math olympiadbench omnimath)

# ---- Smoke-gate expectations for the 1.5B reproduction --------------------
S1MS_EXPECT_VAL_MACRO="${S1MS_EXPECT_VAL_MACRO:-0.1855}"
S1MS_EXPECT_ORACLE_MACRO="${S1MS_EXPECT_ORACLE_MACRO:-0.3773}"
S1MS_GATE_TOL="${S1MS_GATE_TOL:-0.01}"

# ---- Paths (override as needed) -------------------------------------------
# Project checkout on TamIA.
PROJECT_ROOT="${PROJECT_ROOT:-$HOME/CoT-checker}"
# Output root. Per the ablation spec this is runs/s1_model_size_dense/.
RUNS_ROOT="${RUNS_ROOT:-$PROJECT_ROOT/runs/s1_model_size_dense}"

# Frozen Sprint 1 PRM800K split JSONLs (REUSED verbatim, never rebuilt):
#   $PRM_SPLIT_DIR/prm800k_probe_train_40k.jsonl
#   $PRM_SPLIT_DIR/prm800k_val_1k.jsonl
# Point this at the directory that produced the deadline DenseLinear row.
PRM_SPLIT_DIR="${PRM_SPLIT_DIR:-/scratch/d/dchikhi/cot_mech/prestudy_v1/data}"
PRM_TRAIN_JSONL="${PRM_TRAIN_JSONL:-prm800k_probe_train_40k.jsonl}"
PRM_VAL_JSONL="${PRM_VAL_JSONL:-prm800k_val_1k.jsonl}"

# ProcessBench raw subset files. Resolver tries, in order:
#   $PB_DIR/<subset>.json , $PB_DIR/<subset>.jsonl , $PB_DIR/processbench_<subset>.jsonl
PB_DIR="${PB_DIR:-/scratch/d/dchikhi/cot-checker/processbench}"

# ---- Unified HuggingFace cache contract -----------------------------------
HF_CACHE_ROOT="${HF_CACHE_ROOT:-/home/d/dchikhi/links/projects/aip-azouaq/dchikhi/hf_cache}"
# Legacy scratch hub holding pre-fetched 0.5B / 1.5B snapshots to be symlinked in.
HF_SCRATCH_HUB="${HF_SCRATCH_HUB:-/scratch/d/dchikhi/hf_cache/hub}"

# ---- SLURM account / resources --------------------------------------------
S1MS_ACCOUNT="${S1MS_ACCOUNT:-aip-azouaq}"
S1MS_GPUS_PER_TASK="${S1MS_GPUS_PER_TASK:-h100:1}"   # 1 GPU per shard task
S1MS_ENCODE_TIME="${S1MS_ENCODE_TIME:-08:00:00}"
S1MS_TRAIN_TIME="${S1MS_TRAIN_TIME:-01:00:00}"
S1MS_EVAL_TIME="${S1MS_EVAL_TIME:-06:00:00}"
S1MS_AGG_TIME="${S1MS_AGG_TIME:-00:30:00}"
