# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Telegram Bot API token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID (send a message to the bot, then check getUpdates)
TELEGRAM_CHAT_ID=

# OpenRouter API key (for Pass 2 screening — free models available)
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override the API base URL (e.g. for local Ollama: http://localhost:11434/v1)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
